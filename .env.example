PORT=3006
REACT_APP_VERSION=$npm_package_version
REACT_APP_NAME=$npm_package_name

# ---- OIDC (optional, self-host only) ----------------------------------------
# Leave both blank for Mode 1 (no third-party OIDC):
#   SpacetimeDB issues its own anonymous token, persisted in localStorage as
#   "stdb-token". Losing that token loses the identity.
#
# Fill both for Mode 2 (third-party OIDC):
#   The React app uses oidc-client-ts to sign the user in and passes the
#   resulting id_token to SpacetimeDB. SpacetimeDB fetches the issuer's JWKS
#   and validates the JWT itself, deriving a stable Identity from the token's
#   subject. Signing back into the same OIDC account recovers the identity.
#
# OIDC_ISSUER     - your provider's issuer URL (must match the `iss` claim)
# OIDC_CLIENT_ID  - the client_id registered with that provider for this app
#
# Copy this file to `.env` and edit. `.env` is gitignored so your values
# (and any real client IDs) stay out of version control.
OIDC_ISSUER=
OIDC_CLIENT_ID=
